{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Google Sheets Data Schema",
    "type": "object",
    "properties": {
        "SETTINGS": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "key": {
                        "type": "string"
                    },
                    "value": {
                        "type": "string"
                    }
                },
                "required": [
                    "key",
                    "value"
                ]
            }
        }
    }
}